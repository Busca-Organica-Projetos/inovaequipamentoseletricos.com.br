# RewriteRule ^(.*)$ https://www.inovaequipamentoseletricos.com.br/$1 [R=301,L]

# Remove o WWW da URL (usado quando é subdominio)
#RewriteEngine On
#RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
