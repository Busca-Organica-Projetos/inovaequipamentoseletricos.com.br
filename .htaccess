# Para páginas de Loop
# RewriteRule ^(servicos/*) servicos.php [QSA,L]

# errordocument 500 https://www.inovaequipamentoseletricos.com.br/404
# errordocument 404 https://www.inovaequipamentoseletricos.com.br/404
# errordocument 403 https://www.inovaequipamentoseletricos.com.br/404

#--------------------------------------------

RewriteEngine On

# RewriteBase: ambiente DEV (XAMPP em subpasta).
# EM PRODUÇÃO: troque a linha abaixo por "RewriteBase /" (ou comente-a).
RewriteBase /_Dev/inovaequipamentoseletricos.com.br/

# ─── URLs amigáveis de PRODUTO ─────────────────────────────────────
# Força trailing slash em /produto/slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produto/([^/]+)$ produto/$1/ [R=301,L]

# Redireciona produto.php?produtos=slug -> /produto/slug/
# (usa THE_REQUEST para não disparar em rewrites internos — evita loop)
RewriteCond %{THE_REQUEST} \s/+[^?]*produto\.php\?produtos=([^&\s]+)
RewriteRule ^produto\.php$ produto/%1/? [R=301,L]

# Reescreve /produto/slug/ -> produto.php?produtos=slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^produto/([^/]+)/?$ produto.php?produtos=$1 [L,QSA]
# ───────────────────────────────────────────────────────────────────

# ─── URLs amigáveis de PORTFOLIO-ITEM (locação) ────────────────────
# Força trailing slash em /portfolio-item/slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^portfolio-item/([^/]+)$ portfolio-item/$1/ [R=301,L]

# Redireciona portifolio-item.php?slug=xxx -> /portfolio-item/xxx/
# (usa THE_REQUEST para não disparar em rewrites internos — evita loop)
RewriteCond %{THE_REQUEST} \s/+[^?]*portifolio-item\.php\?slug=([^&\s]+)
RewriteRule ^portifolio-item\.php$ portfolio-item/%1/? [R=301,L]

# Reescreve /portfolio-item/slug/ -> portifolio-item.php?slug=slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^portfolio-item/([^/]+)/?$ portifolio-item.php?slug=$1 [L,QSA]
# ───────────────────────────────────────────────────────────────────

# ─── URLs amigáveis de CATEGORY (filtro do blog por categoria) ─────
# Força trailing slash em /category/pai/filho
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^category/([^/]+)/([^/]+)$ category/$1/$2/ [R=301,L]

# Força trailing slash em /category/slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^category/([^/]+)$ category/$1/ [R=301,L]

# Redireciona category.php?slug=xxx -> /category/xxx/
# (usa THE_REQUEST para não disparar em rewrites internos — evita loop)
RewriteCond %{THE_REQUEST} \s/+[^?]*category\.php\?slug=([^&\s]+)
RewriteRule ^category\.php$ category/%1/? [R=301,L]

# Reescreve /category/pai/filho/ -> category.php?slug=filho&parent=pai
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^category/([^/]+)/([^/]+)/?$ category.php?slug=$2&parent=$1 [L,QSA]

# Reescreve /category/slug/ -> category.php?slug=slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^category/([^/]+)/?$ category.php?slug=$1 [L,QSA]
# ───────────────────────────────────────────────────────────────────

# ─── URLs amigáveis de BLOG-ITEM (post individual) ─────────────────
# Força trailing slash em /blog/slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([^/]+)$ blog/$1/ [R=301,L]

# Redireciona blog-item.php?slug=xxx -> /blog/xxx/
# (usa THE_REQUEST para não disparar em rewrites internos — evita loop)
RewriteCond %{THE_REQUEST} \s/+[^?]*blog-item\.php\?slug=([^&\s]+)
RewriteRule ^blog-item\.php$ blog/%1/? [R=301,L]

# Reescreve /blog/slug/ -> blog-item.php?slug=slug
# (NÃO captura /blog/ sozinho, que continua indo para blog.php)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([^/]+)/?$ blog-item.php?slug=$1 [L,QSA]
# ───────────────────────────────────────────────────────────────────

# Remover .php dos arquivos
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php

# Arquivo padrão inicial é o index.php
DirectoryIndex index.php

# Desativa acesso aos arquivos de log "error_log"
RewriteRule (^|/)error_log$ - [L,R=404]

# Desativa a listagem de diretórios que não tem arquivo index
Options -Indexes

# Otimização do site
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/text text/html text/plain text/xml text/css application/x-javascript application/javascript image/jpeg image/png image/gif
</IfModule>

Options -MultiViews

<IfModule mod_headers.c>
    Header unset ETag
</IfModule>

FileETag None
<IfModule mod_expires.c>
    ExpiresActive on
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/cache-manifest "access plus 0 seconds"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/xml "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/rss+xml "access plus 1 hour"
    ExpiresByType application/atom+xml "access plus 1 hour"
    ExpiresByType image/x-icon "access plus 1 week"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType video/ogg "access plus 1 month"
    ExpiresByType audio/ogg "access plus 1 month"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType video/webm "access plus 1 month"
    ExpiresByType text/x-component "access plus 1 month"
    ExpiresByType application/x-font-ttf "access plus 1 month"
    ExpiresByType font/opentype "access plus 1 month"
    ExpiresByType application/x-font-woff "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 month"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
</IfModule>

<IfModule mod_gzip.c>
    mod_gzip_on Yes
    mod_gzip_dechunk Yes
    mod_gzip_item_include file .(html?|txt|css|js|php|pl)$
    mod_gzip_item_include handler ^cgi-script$
    mod_gzip_item_include mime ^text/.*
    mod_gzip_item_include mime ^application/x-javascript.*
    mod_gzip_item_exclude mime ^image/.*
    mod_gzip_item_exclude rspheader ^Content-Encoding:.*gzip.*
</IfModule>

<IfModule mod_deflate.c>

    <IfModule mod_setenvif.c>
        <IfModule mod_headers.c>
        SetEnvIfNoCase ^(Accept-EncodXng|X-cept-Encoding|X{15}|~{15}|-{15})$ ^((gzip|deflate)\s*,?\s*)+|[X~-]{4,13}$ HAVE_Accept-Encoding
        RequestHeader append Accept-Encoding "gzip,deflate" env=HAVE_Accept-Encoding
        </IfModule>
    </IfModule>

    <IfModule mod_filter.c>
        AddOutputFilterByType DEFLATE application/atom+xml \
        application/javascript \
        application/json \
        application/rss+xml \
        application/vnd.ms-fontobject \
        application/x-font-ttf \
        application/x-web-app-manifest+json \
        application/xhtml+xml \
        application/xml \
        font/opentype \
        image/svg+xml \
        image/x-icon \
        text/css \
        text/html \
        text/plain \
        text/x-component \
        text/xml
    </IfModule>

</IfModule>